<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>日次アンケート — test</title>
  <meta name="description" content="1日1回回答できるY/Nアンケート（Firebase Realtime Databaseへ保存）" />
  <style>
    :root{
      --yes:#2ea44f;
      --no:#ea4335;
      --card-bg: rgba(255,255,255,0.82);
      --muted:#666;
      --radius:12px;
      --shadow:0 10px 30px rgba(0,0,0,0.08);
      --bar-bg: rgba(0,0,0,0.06);
    }
    html,body{height:100%;margin:0}
    /* 背景画像（Google Drive 共有ファイルを直接表示） */
    body{
      font-family: "Segoe UI", "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
      background-image: url("https://drive.google.com/uc?export=view&id=1-NmBAe6kjyl-IGru9IiA_gMiBKYcaITe");
      background-position: center top;
      background-repeat: no-repeat;
      background-size: cover; /* 横幅が画面端にちょうど届くように拡大 */
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:28px;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
    }

    .card {
      width:100%;
      max-width:760px;
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding:28px;
      backdrop-filter: blur(6px);
      box-sizing:border-box;
      text-align:center;
    }

    h1 { margin:0 0 8px 0; font-weight:600; font-size:1.25rem; color:#222; }
    .question { font-size:2.2rem; font-weight:700; margin:18px 0 22px 0; color:#111; letter-spacing:1px; }

    .controls { display:flex; gap:18px; justify-content:center; align-items:center; margin-bottom:18px; flex-wrap:wrap; }

    .btn {
      -webkit-tap-highlight-color: transparent;
      appearance:none;
      border: none;
      cursor: pointer;
      border-radius: 14px;
      padding: 16px 28px;
      font-size: 1.05rem;
      font-weight:700;
      color: #fff;
      min-width:140px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
      transition: transform .08s ease, box-shadow .12s ease, opacity .12s ease;
    }
    .btn:active { transform: translateY(1px); }
    .btn:disabled { opacity:0.6; cursor:default; transform:none; box-shadow:none; }

    .btn-yes { background: linear-gradient(180deg,var(--yes), #238636); }
    .btn-no  { background: linear-gradient(180deg,var(--no),  #c5221f); }

    .counts { display:flex; gap:12px; justify-content:center; align-items:center; margin-top:8px; color:var(--muted); font-size:0.95rem; }

    /* 比較バー */
    .bar-wrap {
      margin-top:18px;
      width:100%;
      background:var(--bar-bg);
      border-radius:10px;
      overflow:hidden;
      height:44px;
      display:flex;
      align-items:center;
      position:relative;
    }
    .bar-yes {
      background: linear-gradient(90deg, rgba(46,164,79,0.95), rgba(46,164,79,0.85));
      height:100%;
      display:flex;
      align-items:center;
      justify-content:flex-start;
      padding-left:12px;
      color:#fff;
      font-weight:700;
      transition: width 300ms ease;
      white-space:nowrap;
      box-sizing:border-box;
    }
    .bar-no {
      background: linear-gradient(90deg, rgba(234,67,53,0.95), rgba(234,67,53,0.85));
      height:100%;
      display:flex;
      align-items:center;
      justify-content:flex-end;
      padding-right:12px;
      color:#fff;
      font-weight:700;
      transition: width 300ms ease;
      white-space:nowrap;
      box-sizing:border-box;
    }
    .bar-label {
      font-size:0.95rem;
      text-shadow: 0 1px 0 rgba(0,0,0,0.15);
    }

    .status { margin-top:14px; font-size:0.95rem; color:#222; min-height:1.2em; }

    .note { margin-top:12px; color:var(--muted); font-size:0.9rem; }

    .footer { margin-top:18px; font-size:0.82rem; color:var(--muted); }

    @media (max-width:480px){
      .question { font-size:1.6rem; }
      .btn { padding:12px 16px; min-width:110px; font-size:1rem; }
      .card { padding:18px; }
      .bar-wrap { height:40px; }
    }
  </style>
</head>
<body>
  <main class="card" role="main" aria-labelledby="qTitle">
    <h1 id="qTitle">彼はふにゃオスですか？</h1>
    <div class="question" aria-hidden="true">test</div>

    <div class="controls" role="group" aria-label="回答">
      <button id="btnYes" class="btn btn-yes" aria-pressed="false" aria-label="はい">Y</button>
      <button id="btnNo"  class="btn btn-no"  aria-pressed="false" aria-label="いいえ">N</button>
    </div>

    <div class="counts" aria-live="polite">
      <div>Y: <span id="countY">0</span></div>
      <div>N: <span id="countN">0</span></div>
      <div>合計: <span id="countTotal">0</span></div>
    </div>

    <div class="bar-wrap" aria-hidden="false" aria-label="Y と N の比率">
      <!-- 幅は JS で制御 -->
      <div id="barYes" class="bar-yes" style="width:50%">
        <span class="bar-label" id="barYesLabel">Y 50%</span>
      </div>
      <div id="barNo" class="bar-no" style="width:50%">
        <span class="bar-label" id="barNoLabel">N 50%</span>
      </div>
    </div>

    <div class="status" id="status" role="status" aria-live="polite"></div>

    <div class="note">1日につき1回だけ回答できます。保存形式: <code>soft_dayvote_y</code> と <code>soft_dayvote_n</code>（Realtime DB）。</div>

    <div class="footer">データ保存先: Firebase Realtime Database</div>
  </main>

  <script>
    // Firebase 設定（ユーザー提供）
    const firebaseConfig = {
      apiKey: "AIzaSyAFEhguRtpgokh37YZCtHxjA8tHO4tu6Lg",
      authDomain: "tanuki-nu-vrc-profile.firebaseapp.com",
      databaseURL: "https://tanuki-nu-vrc-profile-default-rtdb.asia-southeast1.firebasedatabase.app",
      projectId: "tanuki-nu-vrc-profile",
      storageBucket: "tanuki-nu-vrc-profile.firebasestorage.app",
      messagingSenderId: "751669057525",
      appId: "1:751669057525:web:cf65d84fdcd2a4416d32bc",
      measurementId: "G-L7JBGHCZ1E"
    };

    // DOM
    const btnYes = document.getElementById('btnYes');
    const btnNo  = document.getElementById('btnNo');
    const countYEl = document.getElementById('countY');
    const countNEl = document.getElementById('countN');
    const countTotalEl = document.getElementById('countTotal');
    const statusEl = document.getElementById('status');
    const barYes = document.getElementById('barYes');
    const barNo = document.getElementById('barNo');
    const barYesLabel = document.getElementById('barYesLabel');
    const barNoLabel = document.getElementById('barNoLabel');

    // 日付キー (YYYY-MM-DD) — ローカルで「今日投票済み」チェックに使用
    function getDateKey(d = new Date()){
      const y = d.getFullYear();
      const m = String(d.getMonth()+1).padStart(2,'0');
      const day = String(d.getDate()).padStart(2,'0');
      return `${y}-${m}-${day}`;
    }
    const dateKey = getDateKey();
    const localVoteKey = `tanukinu_voted_${dateKey}`;

    // スクリプト読み込みユーティリティ
    function loadScript(src){
      return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = src;
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('Failed to load ' + src));
        document.head.appendChild(s);
      });
    }

    // 初期化
    (async function init(){
      try {
        // Firebase compat ライブラリを読み込む
        await loadScript('https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js');
        await loadScript('https://www.gstatic.com/firebasejs/9.22.2/firebase-database-compat.js');

        // 初期化
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        // 保存形式: soft_dayvote_y, soft_dayvote_n (ルート直下)
        const refY = db.ref('/soft_dayvote_y');
        const refN = db.ref('/soft_dayvote_n');

        // 既に投票済みかどうか（ローカルチェック）
        const alreadyVoted = !!localStorage.getItem(localVoteKey);
        setButtonsEnabled(!alreadyVoted);

        // リアルタイムで値を監視
        refY.on('value', snapshot => {
          const y = snapshot.val();
          updateCounts((typeof y === 'number') ? y : 0, null);
        });
        refN.on('value', snapshot => {
          const n = snapshot.val();
          updateCounts(null, (typeof n === 'number') ? n : 0);
        });

        // ボタンイベント
        btnYes.addEventListener('click', () => handleVote('y'));
        btnNo.addEventListener('click', () => handleVote('n'));

        // 内部保持（最新の値）
        let latestY = 0;
        let latestN = 0;
        function updateCounts(y, n){
          if (typeof y === 'number') latestY = y;
          if (typeof n === 'number') latestN = n;
          const total = Math.max(0, latestY + latestN);
          countYEl.textContent = latestY;
          countNEl.textContent = latestN;
          countTotalEl.textContent = total;
          updateBars(latestY, latestN);
        }

        // バー更新
        function updateBars(y, n){
          const total = Math.max(1, y + n); // 0除算防止のため最小1
          const pY = Math.round((y / total) * 100);
          const pN = 100 - pY;
          // 幅をパーセンテージで設定
          barYes.style.width = pY + '%';
          barNo.style.width = pN + '%';
          barYesLabel.textContent = `Y ${pY}% (${y})`;
          barNoLabel.textContent = `N ${pN}% (${n})`;
        }

        // 投票処理: Y は soft_dayvote_y を +1、N は soft_dayvote_n を +1
        async function handleVote(choice){
          if (localStorage.getItem(localVoteKey)) {
            statusEl.textContent = '本日は既に投票済みです。';
            return;
          }

          setButtonsEnabled(false);
          statusEl.textContent = '送信中...';

          try {
            if (choice === 'y') {
              await new Promise((resolve, reject) => {
                refY.transaction(current => {
                  if (current === null || typeof current !== 'number') return 1;
                  return current + 1;
                }, (error, committed, snapshot) => {
                  if (error) reject(error);
                  else if (!committed) reject(new Error('transaction not committed'));
                  else resolve(snapshot.val());
                });
              });
            } else {
              await new Promise((resolve, reject) => {
                refN.transaction(current => {
                  if (current === null || typeof current !== 'number') return 1;
                  return current + 1;
                }, (error, committed, snapshot) => {
                  if (error) reject(error);
                  else if (!committed) reject(new Error('transaction not committed'));
                  else resolve(snapshot.val());
                });
              });
            }

            // ローカルに投票済みフラグを保存（1日限定）
            localStorage.setItem(localVoteKey, JSON.stringify({
              choice: choice,
              timestamp: new Date().toISOString()
            }));

            statusEl.textContent = (choice === 'y') ? 'はい を受け付けました。' : 'いいえ を受け付けました。';
            if (choice === 'y') btnYes.setAttribute('aria-pressed','true'); else btnNo.setAttribute('aria-pressed','true');
          } catch (err) {
            console.error(err);
            statusEl.textContent = '送信に失敗しました。再度お試しください。';
            setButtonsEnabled(true);
          }
        }

        // ボタンの有効/無効切替
        function setButtonsEnabled(enabled){
          btnYes.disabled = !enabled;
          btnNo.disabled  = !enabled;
          if (!enabled) {
            btnYes.style.opacity = '0.9';
            btnNo.style.opacity = '0.9';
          } else {
            btnYes.style.opacity = '';
            btnNo.style.opacity = '';
          }
        }

        // 初期ステータス表示
        if (alreadyVoted) {
          const info = JSON.parse(localStorage.getItem(localVoteKey) || 'null');
          const sign = info && info.choice === 'y' ? 'Y' : 'N';
          statusEl.textContent = `本日は既に投票済み（${sign}）。次回は ${getNextDateString()} に投票できます。`;
        } else {
          statusEl.textContent = '本日まだ投票していません。はい または いいえ を選択してください。';
        }

        function getNextDateString(){
          const d = new Date();
          d.setDate(d.getDate() + 1);
          return d.toLocaleDateString();
        }

      } catch (e) {
        console.error(e);
        statusEl.textContent = '初期化に失敗しました。ネットワークや設定を確認してください。';
        btnYes.disabled = true;
        btnNo.disabled = true;
      }
    })();
  </script>
</body>
</html>
